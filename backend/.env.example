# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.pages.dev

# Auth
SECRET_KEY=change-me-to-a-long-random-string

# Alpaca Paper Trading credentials
# Get these from https://app.alpaca.markets (paper account)
ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# AI — Groq is the primary provider (free tier at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Mistral fallback (free tier at console.mistral.ai) — used if GROQ_API_KEY is not set
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Email (SMTP) — needed for welcome/confirmation emails
# Gmail: create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=your_gmail@gmail.com

# SQLite DB path
# Local dev:
DATABASE_URL=sqlite+aiosqlite:///./upalpha.db
# Production (Fly.io persistent volume — set this in fly secrets):
# DATABASE_URL=sqlite+aiosqlite:////data/upalpha.db
