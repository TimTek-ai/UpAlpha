# ── CORS ─────────────────────────────────────────────────────────────────────
# Local dev: comma-separated list of allowed origins
# Production (beta): set to * to allow all origins
ALLOWED_ORIGINS=*

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./upalpha.db
# Production (Neon PostgreSQL — get from neon.tech dashboard):
# DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── AI — Groq (primary, free at console.groq.com) ────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── AI — Mistral (fallback, free at console.mistral.ai) ──────────────────────
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# ── Alpaca Paper Trading (optional — get from app.alpaca.markets) ─────────────
ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Email / SMTP (optional — needed for welcome emails) ───────────────────────
# Gmail: create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=your_gmail@gmail.com
